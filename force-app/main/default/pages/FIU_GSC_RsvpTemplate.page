        <body id="rsvpBody" style="color: #333">
            <apex:includeLightning />
            <div id="compContainer" />
            <!-- Google Tag Manager (noscript) -->
            <noscript>
                <iframe
                    src="https://www.googletagmanager.com/ns.html?id=GTM-PPN6MT"
                    height="0"
                    width="0"
                    style="display: none; visibility: hidden"
                ></iframe>
            </noscript>
            <!-- End Google Tag Manager (noscript) -->
            <main id="main-content" class="slds-scope">
                <div
                    class="fiu-background-blue banner-flex short banner-container energize cyan"
                    id="banner"
                    style="background-image: url({!backgroundImageUrl})"
                >
                    <div class="headline-container">
                        <div class="row">
                            <div class="columns">
                                <div class="content-flex">
                                    <div class="content">
                                        <img
                                            alt="FIU Business - Florida International University"
                                            class="landing-page-logo"
                                            height="50"
                                            src="{!logoImageUrl}"
                                            width="237"
                                        />
                                        <p class="contact-info">
                                            <span
                                                aria-hidden="true"
                                                class="fa-solid fa-phone"
                                                >&nbsp;</span
                                            >
                                            305-348-0694​ |
                                            <a
                                                class="cta-link-primary"
                                                href="mailto:sales@fiu.edu"
                                                rel="noopener"
                                                target="_blank"
                                                >Contact Us!</a
                                            >
                                        </p>
                                        <h1 class="heading">
                                            <span class="subheading"
                                                >{!startEventWeekDay},
                                                {!startEventMonthDay},
                                                {!startEventYear} •
                                                {!startEventTime} - {!timeZone} </span
                                            >{!eventDescription}
                                        </h1>
                                        <p>
                                            <a
                                                id="registerToday"
                                                class="button button--bright-gold"
                                                href="#SummitEventsRegister:RsvpTemplate:SummitEventRegisterForm"
                                                >Register Today!</a
                                            >
                                        </p>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
                <article aria-hidden="true" aria-label="" id="page-intro">
                    <div class="row content-block white no-padding">
                        <div class="small-12 columns"></div>
                    </div>
                </article>
                <article aria-label="Overview">
                    <div id="eventInstanceDescriptionDivContent" style="display:none"> {!eventInstanceDescription} </div>
                    <div
                        class="fiu-background-white content-block landing-page-intro white-panel"
                    >
                        <div class="row">
                            <div id="disclaimer" style="display: none">
                                <apex:outputText escape="false"
                                    value="{!disclaimerText}"
                                />
                            </div>
                            <div
                                id="bodyDiv"
                                class="small-12 medium-12 columns"
                            >
                                <apex:insert name="body" />
                            </div>
                        </div>
                    </div>
                </article>
                <article id="article-panel">
                    <div id="div-panel">
                        <div class="row">
                            <!-- <div class="columns small-12 medium-12 text-center">
                                <button
                                    type="button"
                                    class="button padding-right-2x"
                                    id="btn-calendar"
                                >
                                    Add Calendar
                                </button>
                                <button
                                    type="button"
                                    class="button padding-right-2x"
                                    id="btn-print"
                                >
                                    Print
                                </button>
                                <button
                                    rendered="{!onlineEvent}"
                                    type="button"
                                    class="button padding-right-2x"
                                    id="btn-website"
                                >
                                    Website
                                </button>
                            </div> -->
                            <div class="columns small-12 medium-12 text-center">
                                <div id="share-with-friends">
                                    <!-- AddToAny BEGIN -->
                                    <strong class="share-icons-title"
                                        >Share with friends:</strong
                                    ><br />
                                    <br />
                                    <div
                                        class="a2a_kit a2a_kit_size_32 a2a_default_style"
                                        style="display: inline-block"
                                    >
                                        <a
                                            class="a2a_dd"
                                            href="https://www.addtoany.com/share"
                                        ></a>
                                        
                                        <a class="a2a_button_facebook" ></a>
                                        <a class="a2a_button_twitter"></a>
                                        <a class="a2a_button_google_plus"></a>
                                        <a class="a2a_button_linkedin"></a>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </article>

                
            </main>

            <footer>
                <div class="row footer-flex">
                    <div class="columns medium-5">
                        <a
                            href="https://sales.fiu.edu/"
                            rel="noopener"
                            target="_blank"
                            ><img
                                alt="FIU Sales"
                                class="footer-logo"
                                src="{!logoImageUrl}"
                                width="316"
                                height="82"
                        /></a>
                        <address>
                            Modesto A. Maidique Campus <br />11200 SW 8th Street, RB307B<br />Miami, Florida 33199
                            <br />305-348-0694​<br />
                            <a href="mailto:sales@fiu.edu">sales@fiu.edu</a>
                        </address>
                    </div>
                    <div class="columns medium-7 links-and-social">
