            ></script>
            <script
                src="{!URLFOR($Resource.sp_rsvp, '/js/rsvp.js')}"
                type="text/javascript"
            ></script>
        </body>
        <script
            src="https://digicdn.fiu.edu/core/_assets/js/core.js?v1.17.0"
            type="text/javascript"
        ></script>

        <script
