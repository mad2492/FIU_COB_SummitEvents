                                    aria-hidden="true"
                                    class="fa-brands fa-facebook"
                                >
                                    <span class="show-for-sr">Facebook</span>
                                </span>
                            </a>
                            <a
                                href="https://www.linkedin.com/edu/school?id=18094"
                                rel="noopener"
                                target="_blank"
                            >
                                <span
                                    aria-hidden="true"
                                    class="fa-brands fa-linkedin"
                                >
                                    <span class="show-for-sr">LinkedIn</span>
                                </span>
                            </a>
                            <a
                                href="https://www.instagram.com/fiubusiness/"
                                rel="noopener"
                                target="_blank"
                            >
                                <span
                                    aria-hidden="true"
                                    class="fa-brands fa-instagram"
                                >
                                    <span class="show-for-sr">Instagram</span>
                                </span>
                            </a>
                            <a
                                href="https://www.youtube.com/fiubusiness"
                                rel="noopener"
                                target="_blank"
                            >
                                <span
                                    aria-hidden="true"
                                    class="fa-brands fa-youtube"
                                >
                                    <span class="show-for-sr">YouTube</span>
                                </span>
                            </a>
                            <a
                                href="https://twitter.com/fiubusiness"
                                rel="noopener"
                                target="_blank"
                            >
                                <span
                                    aria-hidden="true"
                                    class="fa-brands fa-twitter"
                                >
                                    <span class="show-for-sr">Twitter</span>
                                </span>
                            </a>
                        </div>
                    </div>
                </div>
            </footer>
            <script
