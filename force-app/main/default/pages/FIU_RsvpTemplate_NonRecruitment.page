        <script>
        
        $.noConflict();
      $(document).ready(function() {
            
            $("form label:contains('Leave_Blank')").parent('div').parent('div').attr('style', 'position:absolute; left:-9999px; top: -9999px; ') ;
            $("form label:contains('Leave_Blank')").parent('div').find('input').addClass('ohnohoney').attr("autocomplete","new-password").attr("tabindex","-1").attr("aria-autocomplete","none").attr("placeholder","Leave Blank")  ;
            $("form label:contains('Leave_Blank')").text('Leave Blank');
         
            $('form input[id*=\'mobile\']').filter(':not([required]:visible)').eq(0).parent('div').parent('div').parent('div').next().find('abbr').remove(); //remove unnecessary Required asterisk
            
            var zipDiv = $("form label:contains('Zip Code')").parent('div').parent('div') ;
            var mobileDiv = $('form div[id*=\'phoneBlock\']');
            if($(mobileDiv).eq(0) && $(zipDiv))
            {
                $(zipDiv).insertBefore($(mobileDiv).eq(0)).addClass('slds-large-size_3-of-6'); 
            }
            
            if($('div[id*="addInfo"]').find('.slds-col').length <= 1)
            {
               $('div[id*="addInfo"]').css('display','none');
            }
            
            $('form div[id$=":addInfo"]').find('h3').css('display','none');
         
        
          });
          
          
            var gcId = JSON.parse(localStorage.getItem( 'gclid' ));

            jQuery.noConflict();
    jQuery(document).ready(function($) {
          //Customize Managed Form slightly
          $("h4").filter(function() { return ($(this).text() === 'Event Details') }).next('p').next('p').text($('#formattedDateHide').text());
          $('#registerToday').text($('a[id^="SummitEventsRegister:SP_RsvpTemplate:SummitEventRegisterForm"]').text());
            $('form input[id*=\'mobile\']').filter(':not([required]:visible)').eq(0).parent('div').parent('div').parent('div').next().find('abbr').remove(); //remove unnecessary Required asterisk
            
            var zipDiv = $("form label:contains('Zip Code')").parent('div').parent('div') ;
            var mobileDiv = $('form div[id*=\'phoneBlock\']');
            if($(mobileDiv).eq(0) && $(zipDiv))
            {
                $(zipDiv).insertBefore($(mobileDiv).eq(0)).addClass('slds-large-size_3-of-6'); 
            }
            
            if($('div[id*="addInfo"]').find('.slds-col').length <= 1)
            {
               $('div[id*="addInfo"]').css('display','none');
            }
            
              var hdr = $('#mainInfoDiv'); 
              hdr.append($('#eventInstanceDescriptionDiv').text()); 
        
          });
            $Lightning.use("c:facebookRegistrationCompleteApp", function () {
                $Lightning.createComponent(
                    "c:facebookRegistrationComplete",
                    {
                        registrationId: "{!registrationId}",
                        fbc: "{!fbc}",
                        fbp: "{!fbp}",
                        userAgent: "{!userAgent}",
                        clientIpAddress: "{!clientIp}",
                        relativePath: "{!relativePath}",
                        gclId: gcId?.value
                    },
                    "compContainer",
                    function (cmp) {
                        console.log(
                            "c:VFPageApp loaded successfully in VF page"
                        );
                    }
                );
            });
